{
  "name": "project-management-system",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n \"backend,frontend\" -c \"bgBlue.bold,bgMagenta.bold\" \"npm run dev --prefix backend\" \"npm run dev --prefix frontend\"",
    "dev:backend": "npm run dev --prefix backend",
    "dev:frontend": "npm run dev --prefix frontend",
    "build": "npm run build --prefix frontend",
    "setup": "npm install --prefix backend && npm install --prefix frontend",
    "db:migrate": "npm run migrate --prefix backend",
    "db:seed": "npm run seed --prefix backend",
    "db:reset": "npm run db:reset --prefix backend"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.11.2",
    "framer-motion": "^12.38.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-redux": "^9.2.0",
    "react-router-dom": "^7.14.1",
    "recharts": "^3.8.1"
  }
}
