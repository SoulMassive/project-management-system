# ══════════════════════════════════════════════════════════════════════════════
# PROJECT MANAGEMENT SYSTEM — Root .gitignore
# ══════════════════════════════════════════════════════════════════════════════

# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/
jspm_packages/
.pnp
.pnp.js

# ── Build outputs ─────────────────────────────────────────────────────────────
dist/
build/
out/
.next/
.nuxt/
.docusaurus/
.cache/
.parcel-cache/
*.tsbuildinfo

# ── Environment variables (NEVER commit real .env files) ──────────────────────
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
.env.staging
.env.*.local
*.env
# Allow example/template env files
!.env.example
!.env.template
!.env.sample

# ── Logs ──────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── Operating System ──────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
Thumbs.db:encryptable
desktop.ini
ehthumbs.db
$RECYCLE.BIN/

# ── Editors & IDEs ────────────────────────────────────────────────────────────
.vscode/
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/settings.json
.idea/
*.swp
*.swo
*.suo
*.ntvs*
*.njsproj
*.sln
*.sublime-project
*.sublime-workspace

# ── Testing & Coverage ────────────────────────────────────────────────────────
coverage/
.nyc_output/
*.lcov
.jest-cache/

# ── Frontend (Vite / React) ───────────────────────────────────────────────────
frontend/dist/
frontend/dist-ssr/
frontend/.vite/
frontend/.cache/

# ── Backend (Node / Express) ──────────────────────────────────────────────────
backend/dist/
# Keep the uploads folder structure but ignore actual uploaded files
backend/uploads/*
!backend/uploads/.gitkeep
# Backend test/diagnostic scripts (generated temporarily, not part of codebase)
backend/smtp-test.js
backend/src/test-otp-email.ts
backend/src/test-*.ts
backend/src/test-*.js

# ── Prisma (legacy — removed, but keep rule for safety) ──────────────────────
backend/prisma/migrations/
/generated/prisma

# ── Deployment ────────────────────────────────────────────────────────────────
.vercel/
.netlify/

# ── Package manager lockfile backups ─────────────────────────────────────────
*.lock.bak

# ── Misc ──────────────────────────────────────────────────────────────────────
*.pem
*.p12
*.key
*.cert
*.crt
